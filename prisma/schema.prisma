generator client {
  provider        = "prisma-client-js"
  previewFeatures = []
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  allowDirectStatusChange   Boolean      @default(false)
  allowClientComments       Boolean      @default(true)
  allowClientAcceptance     Boolean      @default(true)
  requireClientEmail        Boolean      @default(false)
  requirePinTitle           Boolean      @default(false)
  defaultRenderStatus       RenderStatus @default(REVIEW)
  defaultRenderOrder        String       @default("order")
  maxPinsPerRender          Int?
  autoClosePinsOnAccept     Boolean      @default(false)
  autoArchiveOnAccept       Boolean      @default(false)
  hideCommentCount          Boolean      @default(false)
  clientWelcomeMessage      String?
  clientLogoUrl             String?
  accentColor               String?
  notifyClientOnStatusChange Boolean     @default(true)
  notifyClientOnReply       Boolean      @default(true)
  allowClientVersionRestore Boolean      @default(true)
  showProjectTitle          Boolean      @default(true)
  isAdmin       Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  projects      Project[]
  notifications Notification[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Project {
  id          String   @id @default(cuid())
  title       String
  clientName  String?
  clientEmail String?
  description String?
  shareToken    String    @unique @default(cuid())
  sharePassword String?
  shareExpiresAt DateTime?
  archived      Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt   DateTime @updatedAt
  userId      String

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  rooms   Room[]
  renders Render[]
}

model Room {
  id        String   @id @default(cuid())
  name      String
  type      RoomType @default(INNE)
  icon      String?
  order     Int      @default(0)
  archived  Boolean  @default(false)
  createdAt DateTime @default(now())
  projectId String

  project Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  renders Render[]
  folders Folder[]
}

enum RoomType {
  TOALETA
  WC
  SALON
  KUCHNIA
  SYPIALNIA
  INNE
}

model Folder {
  id        String   @id @default(cuid())
  name      String
  roomId    String
  order     Int      @default(0)
  createdAt DateTime @default(now())

  room    Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  renders Render[]
}

model Render {
  id        String       @id @default(cuid())
  name      String
  fileUrl   String
  fileKey   String
  order     Int          @default(0)
  archived  Boolean      @default(false)
  status    RenderStatus @default(REVIEW)
  viewCount Int          @default(0)
  createdAt DateTime     @default(now())
  projectId String
  roomId    String?
  folderId  String?

  project  Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  room     Room?           @relation(fields: [roomId], references: [id], onDelete: SetNull)
  folder   Folder?         @relation(fields: [folderId], references: [id], onDelete: SetNull)
  comments Comment[]
  versions RenderVersion[]
  versionRestoreRequests VersionRestoreRequest[]
}

model RenderVersion {
  id            String   @id @default(cuid())
  renderId      String
  fileUrl       String
  fileKey       String?
  versionNumber Int
  archivedAt    DateTime @default(now())

  render Render @relation(fields: [renderId], references: [id], onDelete: Cascade)
}

model VersionRestoreRequest {
  id         String   @id @default(cuid())
  renderId   String
  versionId  String
  renderName String
  clientName String
  projectId  String
  shareToken String
  status     String   @default("PENDING")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  render Render @relation(fields: [renderId], references: [id], onDelete: Cascade)
}

enum RenderStatus {
  REVIEW
  ACCEPTED
}

model Comment {
  id        String        @id @default(cuid())
  title     String?
  content   String
  posX      Float
  posY      Float
  status     CommentStatus @default(NEW)
  isInternal Boolean       @default(false)
  author    String
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  renderId  String

  render  Render  @relation(fields: [renderId], references: [id], onDelete: Cascade)
  replies Reply[]
}

model Reply {
  id        String   @id @default(cuid())
  content   String
  author    String
  createdAt DateTime @default(now())
  commentId String

  comment Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)
}

enum CommentStatus {
  NEW
  IN_PROGRESS
  DONE
}

model Notification {
  id           String   @id @default(cuid())
  userId       String
  message      String
  link         String
  read         Boolean  @default(false)
  type         String   @default("info")
  requestId    String?
  createdAt    DateTime @default(now())
  projectId    String?
  projectTitle String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model LoginLog {
  id        String   @id @default(cuid())
  email     String
  userId    String?
  success   Boolean
  createdAt DateTime @default(now())
}

model ActivityLog {
  id        String   @id @default(cuid())
  level     String
  action    String
  message   String
  userId    String?
  meta      String?
  createdAt DateTime @default(now())
}

model StatusChangeRequest {
  id         String   @id @default(cuid())
  renderId   String
  renderName String
  clientName String
  projectId  String
  shareToken String
  status     String   @default("PENDING")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}
