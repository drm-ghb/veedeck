generator client {
  provider        = "prisma-client-js"
  previewFeatures = []
}

datasource db {
  provider = "postgresql"
}

model User {
  id                         String                  @id @default(cuid())
  name                       String?
  email                      String                  @unique
  emailVerified              DateTime?
  image                      String?
  password                   String?
  createdAt                  DateTime                @default(now())
  updatedAt                  DateTime                @updatedAt
  allowDirectStatusChange    Boolean                 @default(false)
  accentColor                String?
  allowClientAcceptance      Boolean                 @default(true)
  allowClientComments        Boolean                 @default(true)
  autoArchiveOnAccept        Boolean                 @default(false)
  autoClosePinsOnAccept      Boolean                 @default(false)
  clientLogoUrl              String?
  clientWelcomeMessage       String?
  defaultRenderOrder         String                  @default("order")
  defaultRenderStatus        RenderStatus            @default(REVIEW)
  hideCommentCount           Boolean                 @default(false)
  maxPinsPerRender           Int?
  notifyClientOnReply        Boolean                 @default(true)
  notifyClientOnStatusChange Boolean                 @default(true)
  requireClientEmail         Boolean                 @default(false)
  requirePinTitle            Boolean                 @default(false)
  allowClientVersionRestore  Boolean                 @default(true)
  isAdmin                    Boolean                 @default(false)
  globalHiddenModules        String[]                @default([])
  listsCategoryOrder         String[]                @default([])
  navMode                    String                  @default("sidebar")
  needsNameSetup             Boolean                 @default(false)
  ownerId                    String?
  showProfileName            Boolean                 @default(false)
  showClientLogo             Boolean                 @default(false)
  colorTheme                 String                  @default("champagne")
  customTheme                Json?
  extensionKey               String?                 @unique
  customCategories           String[]                @default([])
  login                      String?                 @unique
  phone                      String?
  role                       String                  @default("designer")
  viewPreferences            Json?
  avatarUrl                  String?
  fullName                   String?
  phonePrefix                String?                 @default("+48")
  pdfListTemplate            String                  @default("violet")
  isFree                     Boolean                 @default(false)
  trialEndsAt                DateTime?
  contactEmail               String?
  emailNotifEnabled          Boolean                 @default(false)
  emailNotifModules          String[]                @default([])
  accounts                   Account[]
  calendarEvents             CalendarEvent[]
  calendarGuestEntries       CalendarGuest[]
  clients                    Client[]                @relation("DesignerClients")
  contractors                Contractor[]            @relation("DesignerContractors")
  contractorAccount          Contractor?             @relation("ContractorUser")
  discounts                  Discount[]
  ownedDiscussions           Discussion[]            @relation("DiscussionOwner")
  discussionMessages         DiscussionMessage[]     @relation("DiscussionMessageUser")
  discussionParticipations   DiscussionParticipant[] @relation("DiscussionParticipants")
  sentInvitations            Invitation[]            @relation("InvitationDesigner")
  models3d                   Model3D[]
  notes                      Note[]
  notifications              Notification[]
  products                   Product[]
  projects                   Project[]
  projectClientAccounts      ProjectClient[]         @relation("ProjectClientUser")
  sessions                   Session[]
  shoppingLists              ShoppingList[]
  subscription               Subscription?
  surveys                    Survey[]
  assignedTasks              Task[]                  @relation("TaskAssignee")
  createdTasks               Task[]                  @relation("TaskCreator")
  taskComments               TaskComment[]           @relation("TaskCommentAuthor")
  taskStatuses               TaskStatusConfig[]
  owner                      User?                   @relation("TeamMembers", fields: [ownerId], references: [id])
  teamMembers                User[]                  @relation("TeamMembers")
  memberPermission           TeamMemberPermission?   @relation("MemberPermissions")
  ownedMemberPermissions     TeamMemberPermission[]  @relation("OwnedPermissions")
}

model TeamMemberPermission {
  id        String   @id @default(cuid())
  memberId  String   @unique
  ownerId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Widoczność modułów (lista ukrytych slugów)
  hiddenModules String[] @default([])

  // ProjectFlow
  pfCanUpload        Boolean @default(true)
  pfCanDelete        Boolean @default(false)
  pfCanManageFolders Boolean @default(true)

  // Listy zakupowe
  listCanCreate Boolean @default(true)
  listCanDelete Boolean @default(false)

  // Wykonawcy
  contrCanCreate Boolean @default(true)
  contrCanEdit   Boolean @default(true)
  contrCanDelete Boolean @default(false)

  // Projekty & Klienci
  projCanCreate    Boolean  @default(true)
  projCanDelete    Boolean  @default(false)
  allowAllClients  Boolean  @default(true)
  allowedClientIds String[] @default([])

  // Zadania
  taskCanCreate Boolean @default(true)
  taskCanDelete Boolean @default(false)

  // Ankiety
  surveyCanCreate Boolean @default(true)
  surveyCanDelete Boolean @default(false)

  member User @relation("MemberPermissions", fields: [memberId], references: [id], onDelete: Cascade)
  owner  User @relation("OwnedPermissions", fields: [ownerId], references: [id], onDelete: Cascade)
}

model Invitation {
  id         String   @id @default(cuid())
  email      String
  token      String   @unique @default(cuid())
  designerId String
  status     String   @default("PENDING")
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  projectId  String?
  type       String   @default("team")
  designer   User     @relation("InvitationDesigner", fields: [designerId], references: [id], onDelete: Cascade)
}

model Subscription {
  id           String    @id @default(cuid())
  userId       String    @unique
  plan         String
  status       String    @default("active")
  billingName  String?
  billingEmail String?
  cardLast4    String?
  cardBrand    String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  cancelAt     DateTime?
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Discount {
  id         String    @id @default(cuid())
  userId     String
  type       String
  value      Float
  validFrom  DateTime  @default(now())
  validUntil DateTime?
  note       String?
  createdAt  DateTime  @default(now())
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Note {
  id          String           @id @default(cuid())
  title       String?
  content     String
  archived    Boolean          @default(false)
  userId      String
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  attachments NoteAttachment[]
}

model NoteAttachment {
  id        String   @id @default(cuid())
  noteId    String
  name      String
  url       String
  key       String
  createdAt DateTime @default(now())
  note      Note     @relation(fields: [noteId], references: [id], onDelete: Cascade)
}

model CalendarEvent {
  id          String            @id @default(cuid())
  title       String
  type        CalendarEventType
  startAt     DateTime
  endAt       DateTime?
  location    String?
  description String?
  userId      String
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  guests      CalendarGuest[]
}

model CalendarGuest {
  id      String        @id @default(cuid())
  eventId String
  name    String?
  email   String?
  userId  String?
  event   CalendarEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user    User?         @relation(fields: [userId], references: [id])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Client {
  id                String          @id @default(cuid())
  designerId        String
  name              String
  createdAt         DateTime        @default(now())
  archived          Boolean         @default(false)
  addressCity       String?
  addressCountry    String?
  addressPostalCode String?
  addressStreet     String?
  clientCanUpload   Boolean         @default(false)
  description       String?
  endDate           DateTime?
  hiddenModules     String[]        @default([])
  startDate         DateTime?
  designer          User            @relation("DesignerClients", fields: [designerId], references: [id], onDelete: Cascade)
  projects          Project[]
  contacts          ProjectClient[] @relation("ClientContacts")
  assignedSurveys   Survey[]        @relation("SurveyAssignedClient")
}

model Project {
  id                       String                 @id @default(cuid())
  title                    String
  description              String?
  shareToken               String                 @unique @default(cuid())
  createdAt                DateTime               @default(now())
  updatedAt                DateTime               @updatedAt
  userId                   String
  clientEmail              String?
  clientName               String?
  archived                 Boolean                @default(false)
  shareExpiresAt           DateTime?
  sharePassword            String?
  modules                  String[]               @default([])
  pinned                   Boolean                @default(false)
  hiddenModules            String[]               @default([])
  slug                     String?                @unique
  addressCity              String?
  addressCountry           String?
  addressPostalCode        String?
  addressStreet            String?
  clientCanUpload          Boolean                @default(false)
  clientPhone              String?
  endDate                  DateTime?
  startDate                DateTime?
  paymentsSharedWithClient Boolean                @default(false)
  scheduleSharedWithClient Boolean                @default(false)
  clientId                 String?
  contractorAssignments    ContractorAssignment[]
  discussion               Discussion?
  paymentsAsRfProject      Payment[]              @relation("PaymentRfProject")
  paymentGroupsAsRfProject PaymentGroup[]         @relation("PaymentGroupRfProject")
  client                   Client?                @relation(fields: [clientId], references: [id])
  user                     User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  clients                  ProjectClient[]
  renders                  Render[]
  rooms                    Room[]
  schedulePhases           SchedulePhase[]        @relation("SchedulePhaseRfProject")
  shoppingLists            ShoppingList[]
  surveys                  Survey[]
  tasks                    Task[]
}

model ProjectClient {
  id             String            @id @default(cuid())
  name           String
  email          String?
  projectId      String?
  createdAt      DateTime          @default(now())
  isMainContact  Boolean           @default(false)
  phone          String?
  endDate        DateTime?
  startDate      DateTime?
  userId         String?
  order          Int               @default(0)
  totalAmount    Float?
  clientId       String?
  docs           ClientDoc[]
  docFolders     ClientDocFolder[]
  payments       Payment[]
  paymentGroups  PaymentGroup[]
  client         Client?           @relation("ClientContacts", fields: [clientId], references: [id], onDelete: Cascade)
  project        Project?          @relation(fields: [projectId], references: [id])
  user           User?             @relation("ProjectClientUser", fields: [userId], references: [id])
  schedulePhases SchedulePhase[]
  surveys        Survey[]
}

model PaymentGroup {
  id               String         @id @default(cuid())
  clientId         String
  parentId         String?
  name             String
  order            Int            @default(0)
  createdAt        DateTime       @default(now())
  rfProjectId      String?
  hiddenFromClient Boolean        @default(false)
  payments         Payment[]
  client           ProjectClient  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  parent           PaymentGroup?  @relation("PaymentGroupChildren", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  children         PaymentGroup[] @relation("PaymentGroupChildren")
  rfProject        Project?       @relation("PaymentGroupRfProject", fields: [rfProjectId], references: [id])
}

model Payment {
  id             String        @id @default(cuid())
  clientId       String
  groupId        String?
  name           String
  amount         Float
  status         String        @default("pending")
  paidAt         DateTime?
  attachmentUrl  String?
  attachmentName String?
  order          Int           @default(0)
  createdAt      DateTime      @default(now())
  rfProjectId    String?
  client         ProjectClient @relation(fields: [clientId], references: [id], onDelete: Cascade)
  group          PaymentGroup? @relation(fields: [groupId], references: [id])
  rfProject      Project?      @relation("PaymentRfProject", fields: [rfProjectId], references: [id])
}

model ShoppingList {
  id         String        @id @default(cuid())
  name       String
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  userId     String
  projectId  String?
  shareToken String        @unique @default(cuid())
  archived   Boolean       @default(false)
  pinned     Boolean       @default(false)
  slug       String?       @unique
  budget     Float?
  hidePrices Boolean       @default(false)
  order      Int           @default(0)
  sections   ListSection[]
  project    Project?      @relation(fields: [projectId], references: [id])
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ListSection {
  id        String        @id @default(cuid())
  name      String
  order     Int           @default(0)
  createdAt DateTime      @default(now())
  listId    String
  sortBy    String        @default("manual")
  budget    Float?
  unsorted  Boolean       @default(false)
  products  ListProduct[]
  list      ShoppingList  @relation(fields: [listId], references: [id], onDelete: Cascade)
}

model ListProduct {
  id            String               @id @default(cuid())
  name          String
  url           String?
  imageUrl      String?
  price         String?
  manufacturer  String?
  color         String?
  description   String?
  deliveryTime  String?
  order         Int                  @default(0)
  createdAt     DateTime             @default(now())
  sectionId     String
  quantity      Int                  @default(1)
  hidden        Boolean              @default(false)
  optional      Boolean              @default(false)
  approval      String?
  productId     String?
  catalogNumber String?
  supplier      String?
  dimensions    String?
  category      String?
  note          String?
  product       Product?             @relation(fields: [productId], references: [id])
  section       ListSection          @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  comments      ListProductComment[]
}

model ListProductComment {
  id               String             @id @default(cuid())
  content          String
  author           String
  createdAt        DateTime           @default(now())
  productId        String
  viewedByDesigner Boolean            @default(false)
  imageUrl         String?
  product          ListProduct        @relation(fields: [productId], references: [id], onDelete: Cascade)
  replies          ListProductReply[]
}

model ListProductReply {
  id               String             @id @default(cuid())
  content          String
  author           String
  createdAt        DateTime           @default(now())
  commentId        String
  viewedByDesigner Boolean            @default(false)
  comment          ListProductComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
}

model Room {
  id        String   @id @default(cuid())
  name      String
  order     Int      @default(0)
  createdAt DateTime @default(now())
  projectId String
  type      RoomType @default(INNE)
  archived  Boolean  @default(false)
  icon      String?
  pinned    Boolean  @default(false)
  folders   Folder[]
  renders   Render[]
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Folder {
  id        String   @id @default(cuid())
  name      String
  roomId    String
  order     Int      @default(0)
  createdAt DateTime @default(now())
  pinned    Boolean  @default(false)
  archived  Boolean  @default(false)
  room      Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  renders   Render[]
}

model Render {
  id                     String                  @id @default(cuid())
  name                   String
  fileUrl                String
  fileKey                String
  order                  Int                     @default(0)
  createdAt              DateTime                @default(now())
  projectId              String
  roomId                 String?
  archived               Boolean                 @default(false)
  status                 RenderStatus            @default(REVIEW)
  viewCount              Int                     @default(0)
  folderId               String?
  pinned                 Boolean                 @default(false)
  fileType               String                  @default("image")
  comments               Comment[]
  contractorFiles        ContractorFile[]
  folder                 Folder?                 @relation(fields: [folderId], references: [id])
  project                Project                 @relation(fields: [projectId], references: [id], onDelete: Cascade)
  room                   Room?                   @relation(fields: [roomId], references: [id])
  productPins            RenderProductPin[]
  versions               RenderVersion[]
  versionRestoreRequests VersionRestoreRequest[]
  comparisonItems        RenderComparisonItem[]  @relation("ComparisonTarget")
  comparisonSources      RenderComparisonItem[]  @relation("ComparisonSource")
}

model RenderComparisonItem {
  id             String   @id @default(cuid())
  renderId       String
  sourceRenderId String
  displayName    String?
  createdAt      DateTime @default(now())
  render         Render   @relation("ComparisonTarget", fields: [renderId], references: [id], onDelete: Cascade)
  sourceRender   Render   @relation("ComparisonSource", fields: [sourceRenderId], references: [id], onDelete: Cascade)
}

model RenderProductPin {
  id                String         @id @default(cuid())
  renderId          String
  productId         String
  posX              Float
  posY              Float
  createdAt         DateTime       @default(now())
  archivedVersionId String?
  archivedVersion   RenderVersion? @relation("ProductPinArchivedVersion", fields: [archivedVersionId], references: [id])
  product           Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  render            Render         @relation(fields: [renderId], references: [id], onDelete: Cascade)
}

model RenderVersion {
  id                  String             @id @default(cuid())
  renderId            String
  fileUrl             String
  fileKey             String?
  versionNumber       Int
  label               String?
  archivedAt          DateTime           @default(now())
  archivedComments    Comment[]          @relation("CommentArchivedVersion")
  archivedProductPins RenderProductPin[] @relation("ProductPinArchivedVersion")
  render              Render             @relation(fields: [renderId], references: [id], onDelete: Cascade)
}

model VersionRestoreRequest {
  id         String   @id @default(cuid())
  renderId   String
  versionId  String
  renderName String
  clientName String
  projectId  String
  shareToken String
  status     String   @default("PENDING")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  render     Render   @relation(fields: [renderId], references: [id], onDelete: Cascade)
}

model Comment {
  id                String         @id @default(cuid())
  content           String
  posX              Float?
  posY              Float?
  status            CommentStatus  @default(NEW)
  author            String
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  renderId          String
  title             String?
  isInternal        Boolean        @default(false)
  isAiSummary       Boolean        @default(false)
  viewedByDesigner  Boolean        @default(false)
  voiceUrl          String?
  archivedVersionId String?
  replyToAuthor     String?
  replyToContent    String?
  replyToId         String?
  imageUrl          String?
  fromDesigner      Boolean        @default(false)
  posPage           Int?
  archivedVersion   RenderVersion? @relation("CommentArchivedVersion", fields: [archivedVersionId], references: [id])
  render            Render         @relation(fields: [renderId], references: [id], onDelete: Cascade)
  replies           Reply[]
}

model Reply {
  id               String   @id @default(cuid())
  content          String
  author           String
  createdAt        DateTime @default(now())
  commentId        String
  voiceUrl         String?
  replyToAuthor    String?
  replyToContent   String?
  replyToId        String?
  viewedByDesigner Boolean  @default(false)
  comment          Comment  @relation(fields: [commentId], references: [id], onDelete: Cascade)
}

model Notification {
  id           String   @id @default(cuid())
  userId       String
  message      String
  link         String
  read         Boolean  @default(false)
  createdAt    DateTime @default(now())
  projectId    String?
  projectTitle String?
  requestId    String?
  type         String   @default("info")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model LoginLog {
  id        String   @id @default(cuid())
  email     String
  userId    String?
  success   Boolean
  createdAt DateTime @default(now())
}

model ActivityLog {
  id        String   @id @default(cuid())
  level     String
  action    String
  message   String
  userId    String?
  meta      String?
  createdAt DateTime @default(now())
}

model StatusChangeRequest {
  id         String   @id @default(cuid())
  renderId   String
  renderName String
  clientName String
  projectId  String
  shareToken String
  status     String   @default("PENDING")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Product {
  id            String             @id @default(cuid())
  name          String
  url           String?
  imageUrl      String?
  price         String?
  manufacturer  String?
  color         String?
  description   String?
  deliveryTime  String?
  quantity      Int                @default(1)
  createdAt     DateTime           @default(now())
  userId        String
  catalogNumber String?
  supplier      String?
  dimensions    String?
  category      String?
  favorite      Boolean            @default(false)
  listProducts  ListProduct[]
  user          User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  renderPins    RenderProductPin[]
}

model Discussion {
  id                     String                  @id @default(cuid())
  title                  String
  type                   String                  @default("internal")
  ownerId                String
  projectId              String?                 @unique
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  archived               Boolean                 @default(false)
  contractorAssignmentId String?                 @unique
  contractorAssignment   ContractorAssignment?   @relation(fields: [contractorAssignmentId], references: [id])
  owner                  User                    @relation("DiscussionOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  project                Project?                @relation(fields: [projectId], references: [id], onDelete: Cascade)
  messages               DiscussionMessage[]
  participants           DiscussionParticipant[]
  readReceipts           DiscussionReadReceipt[]
}

model DiscussionParticipant {
  id           String     @id @default(cuid())
  discussionId String
  userId       String
  addedAt      DateTime   @default(now())
  discussion   Discussion @relation(fields: [discussionId], references: [id], onDelete: Cascade)
  user         User       @relation("DiscussionParticipants", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([discussionId, userId])
}

model DiscussionMessage {
  id             String                  @id @default(cuid())
  discussionId   String
  content        String
  authorName     String
  userId         String?
  clientEmail    String?
  sourceType     String                  @default("chat")
  sourceId       String?
  sourceUrl      String?
  sourceName     String?
  createdAt      DateTime                @default(now())
  attachmentName String?
  attachmentType String?
  attachmentUrl  String?
  sourceImageUrl String?
  editedAt       DateTime?
  replyToAuthor  String?
  replyToContent String?
  replyToId      String?
  discussion     Discussion              @relation(fields: [discussionId], references: [id], onDelete: Cascade)
  user           User?                   @relation("DiscussionMessageUser", fields: [userId], references: [id])
  readReceipts   DiscussionReadReceipt[]
  reactions      DiscussionMessageReaction[]
}

model DiscussionMessageReaction {
  id        String            @id @default(cuid())
  messageId String
  userId    String
  userName  String
  emoji     String
  createdAt DateTime          @default(now())
  message   DiscussionMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
}

model DiscussionReadReceipt {
  id            String             @id @default(cuid())
  discussionId  String
  readerId      String
  readerName    String
  readerType    String
  lastMessageId String?
  readAt        DateTime           @default(now())
  discussion    Discussion         @relation(fields: [discussionId], references: [id], onDelete: Cascade)
  lastMessage   DiscussionMessage? @relation(fields: [lastMessageId], references: [id])

  @@unique([discussionId, readerId])
}

model ClientDocFolder {
  id        String        @id @default(cuid())
  clientId  String
  name      String
  order     Int           @default(0)
  pinned    Boolean       @default(false)
  archived  Boolean       @default(false)
  createdAt DateTime      @default(now())
  docs      ClientDoc[]
  client    ProjectClient @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

model ClientDoc {
  id        String           @id @default(cuid())
  clientId  String
  folderId  String?
  name      String
  fileUrl   String
  fileKey   String
  fileType  String           @default("file")
  order     Int              @default(0)
  pinned    Boolean          @default(false)
  archived  Boolean          @default(false)
  createdAt DateTime         @default(now())
  client    ProjectClient    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  folder    ClientDocFolder? @relation(fields: [folderId], references: [id])
}

model Task {
  id          String        @id @default(cuid())
  title       String
  description String?
  status      String        @default("TODO")
  priority    TaskPriority  @default(MEDIUM)
  dueDate     DateTime?
  projectId   String?
  creatorId   String
  assigneeId  String?
  ownerId     String
  parentId    String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  assignee    User?         @relation("TaskAssignee", fields: [assigneeId], references: [id])
  creator     User          @relation("TaskCreator", fields: [creatorId], references: [id], onDelete: Cascade)
  parent      Task?         @relation("SubTasks", fields: [parentId], references: [id], onDelete: Cascade)
  subTasks    Task[]        @relation("SubTasks")
  project     Project?      @relation(fields: [projectId], references: [id])
  comments    TaskComment[]
}

model TaskStatusConfig {
  id        String   @id @default(cuid())
  value     String
  label     String
  color     String   @default("#6b7280")
  order     Int      @default(0)
  ownerId   String
  createdAt DateTime @default(now())
  owner     User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@unique([ownerId, value])
}

model TaskComment {
  id        String   @id @default(cuid())
  body      String
  taskId    String
  authorId  String
  createdAt DateTime @default(now())
  author    User     @relation("TaskCommentAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
}

model Survey {
  id             String           @id @default(cuid())
  name           String
  slug           String           @unique
  shareToken     String           @unique @default(cuid())
  status         String           @default("DRAFT")
  archived       Boolean          @default(false)
  pinned         Boolean          @default(false)
  order          Int              @default(0)
  userId         String
  projectId      String?
  clientId       String?
  lastReminderAt    DateTime?
  aiSummary         String?
  aiSummaryMarkdown String?
  aiSummaryAt       DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  isTemplate     Boolean          @default(false)
  assignedClientId String?
  client           ProjectClient?   @relation(fields: [clientId], references: [id])
  project          Project?         @relation(fields: [projectId], references: [id])
  assignedClient   Client?          @relation("SurveyAssignedClient", fields: [assignedClientId], references: [id])
  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  questions      SurveyQuestion[]
  responses      SurveyResponse[]
  sections       SurveySection[]
}

model SurveySection {
  id        String           @id @default(cuid())
  name      String
  order     Int              @default(0)
  surveyId  String
  questions SurveyQuestion[]
  survey    Survey           @relation(fields: [surveyId], references: [id], onDelete: Cascade)
}

model SurveyQuestion {
  id          String         @id @default(cuid())
  label       String
  description String?
  type        String
  required    Boolean        @default(false)
  order       Int            @default(0)
  options     Json?
  config      Json?
  sectionId   String?
  surveyId    String
  answers     SurveyAnswer[]
  section     SurveySection? @relation(fields: [sectionId], references: [id])
  survey      Survey         @relation(fields: [surveyId], references: [id], onDelete: Cascade)
}

model SurveyResponse {
  id              String         @id @default(cuid())
  respondentEmail String
  respondentName  String?
  completedAt     DateTime?
  surveyId        String
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  viewCount       Int            @default(0)
  answers         SurveyAnswer[]
  survey          Survey         @relation(fields: [surveyId], references: [id], onDelete: Cascade)
}

model SurveyAnswer {
  id         String         @id @default(cuid())
  value      Json
  questionId String
  responseId String
  createdAt  DateTime       @default(now())
  question   SurveyQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  response   SurveyResponse @relation(fields: [responseId], references: [id], onDelete: Cascade)
}

model Model3D {
  id           String   @id @default(cuid())
  userId       String
  name         String
  category     String
  meshyTaskId  String?
  thumbnailUrl String?
  urlGlb       String?
  urlObj       String?
  urlStl       String?
  urlFbx       String?
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SchedulePhase {
  id          String         @id @default(cuid())
  clientId    String
  rfProjectId String?
  name        String
  startDate   DateTime?
  endDate     DateTime?
  done        Boolean        @default(false)
  hidden      Boolean        @default(false)
  order       Int            @default(0)
  createdAt   DateTime       @default(now())
  items       ScheduleItem[]
  client      ProjectClient  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  rfProject   Project?       @relation("SchedulePhaseRfProject", fields: [rfProjectId], references: [id])
}

model ScheduleItem {
  id          String        @id @default(cuid())
  phaseId     String
  name        String
  description String?
  startDate   DateTime?
  endDate     DateTime?
  done        Boolean       @default(false)
  hidden      Boolean       @default(false)
  order       Int           @default(0)
  createdAt   DateTime      @default(now())
  isSection   Boolean       @default(false)
  phase       SchedulePhase @relation(fields: [phaseId], references: [id], onDelete: Cascade)
}

model Contractor {
  id          String                 @id @default(cuid())
  designerId  String
  userId      String?                @unique
  name        String
  company     String?
  trade       String?
  email       String?
  phone       String?
  createdAt   DateTime               @default(now())
  designer    User                   @relation("DesignerContractors", fields: [designerId], references: [id], onDelete: Cascade)
  user        User?                  @relation("ContractorUser", fields: [userId], references: [id])
  assignments ContractorAssignment[]
}

model ContractorAssignment {
  id                   String             @id @default(cuid())
  contractorId         String
  projectId            String
  designerId           String
  archived             Boolean            @default(false)
  createdAt            DateTime           @default(now())
  designerContactName  String?
  designerContactPhone String?
  investmentCity       String?
  investmentCountry    String?
  investmentPostalCode String?
  investmentStreet     String?
  investorContactName  String?
  investorContactPhone String?
  projectNotes         String?
  contractor           Contractor         @relation(fields: [contractorId], references: [id], onDelete: Cascade)
  project              Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  folders              ContractorFolder[]
  discussion           Discussion?

  @@unique([contractorId, projectId])
}

model ContractorFolder {
  id           String               @id @default(cuid())
  assignmentId String
  name         String
  type         String
  visible      Boolean              @default(true)
  order        Int                  @default(0)
  createdAt    DateTime             @default(now())
  parentId       String?
  sourceFolderId String?
  files          ContractorFile[]
  assignment   ContractorAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  parent       ContractorFolder?    @relation("SubFolders", fields: [parentId], references: [id], onDelete: Cascade)
  subfolders   ContractorFolder[]   @relation("SubFolders")
}

model ContractorFile {
  id           String                  @id @default(cuid())
  folderId     String
  name         String
  renderId     String?
  fileUrl      String?
  fileKey      String?
  fileType     String                  @default("image")
  uploadedById String
  createdAt    DateTime                @default(now())
  folder       ContractorFolder        @relation(fields: [folderId], references: [id], onDelete: Cascade)
  render       Render?                 @relation(fields: [renderId], references: [id])
  comments     ContractorFileComment[]
}

model ContractorFileComment {
  id                 String                @id @default(cuid())
  content            String
  author             String
  authorRole         String                @default("contractor")
  createdAt          DateTime              @default(now())
  fileId             String
  viewedByDesigner   Boolean               @default(false)
  viewedByContractor Boolean               @default(false)
  posX               Float?
  posY               Float?
  title              String?
  file               ContractorFile        @relation(fields: [fileId], references: [id], onDelete: Cascade)
  replies            ContractorFileReply[]
}

model ContractorFileReply {
  id                 String                @id @default(cuid())
  content            String
  author             String
  authorRole         String                @default("designer")
  createdAt          DateTime              @default(now())
  commentId          String
  viewedByContractor Boolean               @default(false)
  comment            ContractorFileComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
}

enum CalendarEventType {
  WYDARZENIE
  ZADANIE
  PRZYPOMNIENIE
}

enum RoomType {
  TOALETA
  WC
  SALON
  KUCHNIA
  SYPIALNIA
  INNE
}

enum RenderStatus {
  REVIEW
  ACCEPTED
}

enum CommentStatus {
  NEW
  IN_PROGRESS
  DONE
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
}
