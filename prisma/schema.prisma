generator client {
  provider        = "prisma-client-js"
  previewFeatures = []
}

datasource db {
  provider = "postgresql"
}

model User {
  id                         String         @id @default(cuid())
  name                       String?
  email                      String         @unique
  emailVerified              DateTime?
  image                      String?
  password                   String?
  createdAt                  DateTime       @default(now())
  updatedAt                  DateTime       @updatedAt
  role                       String         @default("designer") // "designer" | "client"
  fullName                   String?                             // imię i nazwisko
  avatarUrl                  String?                             // custom avatar
  phonePrefix                String?        @default("+48")      // country code prefix
  login                      String?        @unique              // client login e.g. "drychlik"
  phone                      String?                             // contact phone
  allowDirectStatusChange    Boolean        @default(false)
  accentColor                String?
  allowClientAcceptance      Boolean        @default(true)
  allowClientComments        Boolean        @default(true)
  autoArchiveOnAccept        Boolean        @default(false)
  autoClosePinsOnAccept      Boolean        @default(false)
  clientLogoUrl              String?
  clientWelcomeMessage       String?
  defaultRenderOrder         String         @default("order")
  defaultRenderStatus        RenderStatus   @default(REVIEW)
  hideCommentCount           Boolean        @default(false)
  maxPinsPerRender           Int?
  notifyClientOnReply        Boolean        @default(true)
  notifyClientOnStatusChange Boolean        @default(true)
  requireClientEmail         Boolean        @default(false)
  requirePinTitle            Boolean        @default(false)
  allowClientVersionRestore  Boolean        @default(true)
  showProfileName            Boolean        @default(false)
  showClientLogo             Boolean        @default(false)
  isAdmin                    Boolean        @default(false)
  needsNameSetup             Boolean        @default(false)
  globalHiddenModules        String[]       @default([])
  listsCategoryOrder         String[]       @default([])
  navMode                    String         @default("sidebar")
  colorTheme                 String         @default("champagne")
  pdfListTemplate            String         @default("violet")
  extensionKey               String?        @unique
  customCategories           String[]       @default([])
  viewPreferences            Json?
  ownerId                    String?
  owner                      User?          @relation("TeamMembers", fields: [ownerId], references: [id])
  teamMembers                User[]         @relation("TeamMembers")
  accounts                   Account[]
  calendarEvents             CalendarEvent[]
  calendarGuestEntries       CalendarGuest[]
  notifications              Notification[]
  notes                      Note[]
  products                   Product[]
  projects                   Project[]
  sessions                   Session[]
  shoppingLists              ShoppingList[]
  sentInvitations            Invitation[]   @relation("InvitationDesigner")
  ownedDiscussions           Discussion[]   @relation("DiscussionOwner")
  discussionMessages         DiscussionMessage[] @relation("DiscussionMessageUser")
  projectClientAccounts      ProjectClient[] @relation("ProjectClientUser")
  createdTasks               Task[]         @relation("TaskCreator")
  assignedTasks              Task[]         @relation("TaskAssignee")
  taskComments               TaskComment[]  @relation("TaskCommentAuthor")
}

model Invitation {
  id         String   @id @default(cuid())
  email      String
  token      String   @unique @default(cuid())
  designerId String
  designer   User     @relation("InvitationDesigner", fields: [designerId], references: [id], onDelete: Cascade)
  status     String   @default("PENDING")
  expiresAt  DateTime
  createdAt  DateTime @default(now())
}

model Note {
  id          String           @id @default(cuid())
  title       String?
  content     String
  archived    Boolean          @default(false)
  userId      String
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  attachments NoteAttachment[]
}

model NoteAttachment {
  id        String   @id @default(cuid())
  noteId    String
  name      String
  url       String
  key       String
  createdAt DateTime @default(now())
  note      Note     @relation(fields: [noteId], references: [id], onDelete: Cascade)
}

model CalendarEvent {
  id          String            @id @default(cuid())
  title       String
  type        CalendarEventType
  startAt     DateTime
  endAt       DateTime?
  location    String?
  description String?
  userId      String
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  guests      CalendarGuest[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
}

model CalendarGuest {
  id      String        @id @default(cuid())
  eventId String
  name    String?
  email   String?
  userId  String?
  user    User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  event   CalendarEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

enum CalendarEventType {
  WYDARZENIE
  ZADANIE
  PRZYPOMNIENIE
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Project {
  id             String          @id @default(cuid())
  title          String
  description    String?
  shareToken     String          @unique @default(cuid())
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  userId         String
  clientEmail    String?
  clientName     String?
  clientPhone    String?
  archived       Boolean         @default(false)
  shareExpiresAt DateTime?
  sharePassword  String?
  modules        String[]        @default([])
  pinned             Boolean         @default(false)
  hiddenModules      String[]        @default([])
  slug               String?         @unique
  addressCountry     String?
  addressCity        String?
  addressPostalCode  String?
  addressStreet      String?
  clientCanUpload    Boolean         @default(false)
  startDate          DateTime?
  endDate            DateTime?
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  clients        ProjectClient[]
  renders        Render[]
  rooms          Room[]
  shoppingLists  ShoppingList[]
  discussion     Discussion?
  tasks          Task[]
}

model ProjectClient {
  id            String         @id @default(cuid())
  name          String
  email         String?
  phone         String?
  projectId     String
  createdAt     DateTime       @default(now())
  isMainContact Boolean        @default(false)
  order         Int            @default(0)
  startDate     DateTime?
  endDate       DateTime?
  userId        String?
  totalAmount   Float?
  project       Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user          User?          @relation("ProjectClientUser", fields: [userId], references: [id], onDelete: SetNull)
  paymentGroups PaymentGroup[]
  payments      Payment[]
  docFolders    ClientDocFolder[]
  docs          ClientDoc[]
}

model PaymentGroup {
  id        String         @id @default(cuid())
  clientId  String
  parentId  String?
  name      String
  order     Int            @default(0)
  createdAt DateTime       @default(now())
  client    ProjectClient  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  parent    PaymentGroup?  @relation("PaymentGroupChildren", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  children  PaymentGroup[] @relation("PaymentGroupChildren")
  payments  Payment[]
}

model Payment {
  id             String         @id @default(cuid())
  clientId       String
  groupId        String?
  name           String
  amount         Float
  status         String         @default("pending")
  attachmentUrl  String?
  attachmentName String?
  order          Int            @default(0)
  createdAt      DateTime       @default(now())
  client         ProjectClient  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  group          PaymentGroup?  @relation(fields: [groupId], references: [id], onDelete: SetNull)
}

model ShoppingList {
  id         String        @id @default(cuid())
  name       String
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  userId     String
  projectId  String?
  shareToken String        @unique @default(cuid())
  archived   Boolean       @default(false)
  pinned     Boolean       @default(false)
  order      Int           @default(0)
  slug       String?       @unique
  budget     Float?
  hidePrices Boolean       @default(false)
  sections   ListSection[]
  project    Project?      @relation(fields: [projectId], references: [id])
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ListSection {
  id        String        @id @default(cuid())
  name      String
  order     Int           @default(0)
  createdAt DateTime      @default(now())
  listId    String
  sortBy    String        @default("manual")
  budget    Float?
  unsorted  Boolean       @default(false)
  products  ListProduct[]
  list      ShoppingList  @relation(fields: [listId], references: [id], onDelete: Cascade)
}

model ListProduct {
  id           String               @id @default(cuid())
  name         String
  url          String?
  imageUrl     String?
  price        String?
  manufacturer String?
  color        String?
  dimensions   String?
  description  String?
  deliveryTime String?
  order        Int                  @default(0)
  createdAt    DateTime             @default(now())
  sectionId    String
  quantity     Int                  @default(1)
  category     String?
  hidden        Boolean              @default(false)
  approval      String?
  productId     String?
  supplier      String?
  catalogNumber String?
  note          String?
  section      ListSection          @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  product      Product?             @relation(fields: [productId], references: [id], onDelete: SetNull)
  comments     ListProductComment[]
}

model ListProductComment {
  id               String             @id @default(cuid())
  content          String
  author           String
  createdAt        DateTime           @default(now())
  productId        String
  viewedByDesigner Boolean            @default(false)
  imageUrl         String?
  product          ListProduct        @relation(fields: [productId], references: [id], onDelete: Cascade)
  replies          ListProductReply[]
}

model ListProductReply {
  id        String             @id @default(cuid())
  content   String
  author    String
  createdAt DateTime           @default(now())
  commentId String
  comment   ListProductComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
}

model Room {
  id        String   @id @default(cuid())
  name      String
  order     Int      @default(0)
  createdAt DateTime @default(now())
  projectId String
  type      RoomType @default(INNE)
  archived  Boolean  @default(false)
  icon      String?
  pinned    Boolean  @default(false)
  folders   Folder[]
  renders   Render[]
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Folder {
  id        String   @id @default(cuid())
  name      String
  roomId    String
  order     Int      @default(0)
  createdAt DateTime @default(now())
  pinned    Boolean  @default(false)
  archived  Boolean  @default(false)
  room      Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  renders   Render[]
}

model Render {
  id                     String                  @id @default(cuid())
  name                   String
  fileUrl                String
  fileKey                String
  order                  Int                     @default(0)
  createdAt              DateTime                @default(now())
  projectId              String
  roomId                 String?
  archived               Boolean                 @default(false)
  status                 RenderStatus            @default(REVIEW)
  viewCount              Int                     @default(0)
  folderId               String?
  pinned                 Boolean                 @default(false)
  fileType               String                  @default("image")
  comments               Comment[]
  productPins            RenderProductPin[]
  folder                 Folder?                 @relation(fields: [folderId], references: [id])
  project                Project                 @relation(fields: [projectId], references: [id], onDelete: Cascade)
  room                   Room?                   @relation(fields: [roomId], references: [id])
  versions               RenderVersion[]
  versionRestoreRequests VersionRestoreRequest[]
}

model RenderProductPin {
  id        String   @id @default(cuid())
  renderId  String
  productId String
  posX      Float
  posY      Float
  createdAt DateTime @default(now())
  archivedVersionId String?

  render          Render         @relation(fields: [renderId], references: [id], onDelete: Cascade)
  product         Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  archivedVersion RenderVersion? @relation("ProductPinArchivedVersion", fields: [archivedVersionId], references: [id])
}

model RenderVersion {
  id            String   @id @default(cuid())
  renderId      String
  fileUrl       String
  fileKey       String?
  versionNumber Int
  archivedAt    DateTime @default(now())
  render        Render   @relation(fields: [renderId], references: [id], onDelete: Cascade)
  archivedComments    Comment[]          @relation("CommentArchivedVersion")
  archivedProductPins RenderProductPin[] @relation("ProductPinArchivedVersion")
}

model VersionRestoreRequest {
  id         String   @id @default(cuid())
  renderId   String
  versionId  String
  renderName String
  clientName String
  projectId  String
  shareToken String
  status     String   @default("PENDING")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  render     Render   @relation(fields: [renderId], references: [id], onDelete: Cascade)
}

model Comment {
  id         String        @id @default(cuid())
  content    String
  posX       Float?
  posY       Float?
  status     CommentStatus @default(NEW)
  author     String
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  renderId   String
  title      String?
  isInternal        Boolean       @default(false)
  isAiSummary       Boolean       @default(false)
  viewedByDesigner  Boolean       @default(false)
  voiceUrl          String?
  imageUrl          String?
  archivedVersionId String?
  replyToId         String?
  replyToContent    String?
  replyToAuthor     String?
  render          Render         @relation(fields: [renderId], references: [id], onDelete: Cascade)
  archivedVersion RenderVersion? @relation("CommentArchivedVersion", fields: [archivedVersionId], references: [id])
  replies    Reply[]
}

model Reply {
  id             String   @id @default(cuid())
  content        String
  author         String
  voiceUrl       String?
  replyToId      String?
  replyToContent String?
  replyToAuthor  String?
  createdAt      DateTime @default(now())
  commentId      String
  comment        Comment  @relation(fields: [commentId], references: [id], onDelete: Cascade)
}

model Notification {
  id           String   @id @default(cuid())
  userId       String
  message      String
  link         String
  read         Boolean  @default(false)
  createdAt    DateTime @default(now())
  projectId    String?
  projectTitle String?
  requestId    String?
  type         String   @default("info")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model LoginLog {
  id        String   @id @default(cuid())
  email     String
  userId    String?
  success   Boolean
  createdAt DateTime @default(now())
}

model ActivityLog {
  id        String   @id @default(cuid())
  level     String
  action    String
  message   String
  userId    String?
  meta      String?
  createdAt DateTime @default(now())
}

model StatusChangeRequest {
  id         String   @id @default(cuid())
  renderId   String
  renderName String
  clientName String
  projectId  String
  shareToken String
  status     String   @default("PENDING")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Product {
  id           String               @id @default(cuid())
  name         String
  url          String?
  imageUrl     String?
  price        String?
  manufacturer String?
  color        String?
  dimensions   String?
  description  String?
  deliveryTime  String?
  quantity      Int                  @default(1)
  category      String?
  supplier      String?
  catalogNumber String?
  createdAt     DateTime             @default(now())
  userId        String
  user         User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  listProducts ListProduct[]
  renderPins   RenderProductPin[]
}

model Discussion {
  id        String   @id @default(cuid())
  title     String
  type      String   @default("internal") // "project" | "internal"
  ownerId   String
  projectId String?  @unique
  archived  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner        User                    @relation("DiscussionOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  project      Project?                @relation(fields: [projectId], references: [id], onDelete: Cascade)
  messages     DiscussionMessage[]
  readReceipts DiscussionReadReceipt[]
}

model DiscussionMessage {
  id           String   @id @default(cuid())
  discussionId String
  content      String
  authorName   String
  userId       String?
  clientEmail  String?
  sourceType   String   @default("chat") // "chat" | "render_comment" | "render_pin" | "product_comment"
  sourceId        String?
  sourceUrl       String?
  sourceName      String?
  sourceImageUrl  String?
  attachmentUrl  String?
  attachmentName String?
  attachmentType String? // "image" | "document"
  replyToId      String?
  replyToContent String?
  replyToAuthor  String?
  createdAt      DateTime @default(now())
  editedAt       DateTime?

  discussion   Discussion              @relation(fields: [discussionId], references: [id], onDelete: Cascade)
  user         User?                   @relation("DiscussionMessageUser", fields: [userId], references: [id], onDelete: SetNull)
  readReceipts DiscussionReadReceipt[]
}

model DiscussionReadReceipt {
  id            String   @id @default(cuid())
  discussionId  String
  readerId      String   // userId for designers, "client:<authorName>" for clients
  readerName    String
  readerType    String   // "designer" | "client"
  lastMessageId String?
  readAt        DateTime @default(now())

  discussion   Discussion        @relation(fields: [discussionId], references: [id], onDelete: Cascade)
  lastMessage  DiscussionMessage? @relation(fields: [lastMessageId], references: [id], onDelete: SetNull)

  @@unique([discussionId, readerId])
}


enum RoomType {
  TOALETA
  WC
  SALON
  KUCHNIA
  SYPIALNIA
  INNE
}

enum RenderStatus {
  REVIEW
  ACCEPTED
}

enum CommentStatus {
  NEW
  IN_PROGRESS
  DONE
}

model ClientDocFolder {
  id        String         @id @default(cuid())
  clientId  String
  name      String
  order     Int            @default(0)
  pinned    Boolean        @default(false)
  archived  Boolean        @default(false)
  createdAt DateTime       @default(now())
  client    ProjectClient  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  docs      ClientDoc[]
}

model ClientDoc {
  id        String           @id @default(cuid())
  clientId  String
  folderId  String?
  name      String
  fileUrl   String
  fileKey   String
  fileType  String           @default("file")
  order     Int              @default(0)
  pinned    Boolean          @default(false)
  archived  Boolean          @default(false)
  createdAt DateTime         @default(now())
  client    ProjectClient    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  folder    ClientDocFolder? @relation(fields: [folderId], references: [id], onDelete: SetNull)
}

model Task {
  id          String       @id @default(cuid())
  title       String
  description String?
  status      TaskStatus   @default(TODO)
  priority    TaskPriority @default(MEDIUM)
  dueDate     DateTime?
  projectId   String?
  project     Project?     @relation(fields: [projectId], references: [id], onDelete: SetNull)
  creatorId   String
  creator     User         @relation("TaskCreator", fields: [creatorId], references: [id], onDelete: Cascade)
  assigneeId  String?
  assignee    User?        @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  ownerId     String
  parentId    String?
  parent      Task?        @relation("SubTasks", fields: [parentId], references: [id], onDelete: Cascade)
  subTasks    Task[]       @relation("SubTasks")
  comments    TaskComment[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model TaskComment {
  id        String   @id @default(cuid())
  body      String
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation("TaskCommentAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
}
