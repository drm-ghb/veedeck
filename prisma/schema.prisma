generator client {
  provider        = "prisma-client-js"
  previewFeatures = []
}

datasource db {
  provider = "postgresql"
}

model User {
  id                         String         @id @default(cuid())
  name                       String?
  email                      String         @unique
  emailVerified              DateTime?
  image                      String?
  password                   String?
  createdAt                  DateTime       @default(now())
  updatedAt                  DateTime       @updatedAt
  allowDirectStatusChange    Boolean        @default(false)
  accentColor                String?
  allowClientAcceptance      Boolean        @default(true)
  allowClientComments        Boolean        @default(true)
  autoArchiveOnAccept        Boolean        @default(false)
  autoClosePinsOnAccept      Boolean        @default(false)
  clientLogoUrl              String?
  clientWelcomeMessage       String?
  defaultRenderOrder         String         @default("order")
  defaultRenderStatus        RenderStatus   @default(REVIEW)
  hideCommentCount           Boolean        @default(false)
  maxPinsPerRender           Int?
  notifyClientOnReply        Boolean        @default(true)
  notifyClientOnStatusChange Boolean        @default(true)
  requireClientEmail         Boolean        @default(false)
  requirePinTitle            Boolean        @default(false)
  allowClientVersionRestore  Boolean        @default(true)
  showProjectTitle           Boolean        @default(true)
  isAdmin                    Boolean        @default(false)
  globalHiddenModules        String[]       @default([])
  listsCategoryOrder         String[]       @default([])
  navMode                    String         @default("dashboard")
  accounts                   Account[]
  notifications              Notification[]
  products                   Product[]
  projects                   Project[]
  sessions                   Session[]
  shoppingLists              ShoppingList[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Project {
  id             String          @id @default(cuid())
  title          String
  description    String?
  shareToken     String          @unique @default(cuid())
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  userId         String
  clientEmail    String?
  clientName     String?
  archived       Boolean         @default(false)
  shareExpiresAt DateTime?
  sharePassword  String?
  modules        String[]        @default([])
  pinned             Boolean         @default(false)
  hiddenModules      String[]        @default([])
  slug               String?         @unique
  addressCountry     String?
  addressCity        String?
  addressPostalCode  String?
  addressStreet      String?
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  clients        ProjectClient[]
  renders        Render[]
  rooms          Room[]
  shoppingLists  ShoppingList[]
}

model ProjectClient {
  id            String   @id @default(cuid())
  name          String
  email         String?
  projectId     String
  createdAt     DateTime @default(now())
  isMainContact Boolean  @default(false)
  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model ShoppingList {
  id         String        @id @default(cuid())
  name       String
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  userId     String
  projectId  String?
  shareToken String        @unique @default(cuid())
  archived   Boolean       @default(false)
  pinned     Boolean       @default(false)
  slug       String?       @unique
  budget     Float?
  sections   ListSection[]
  project    Project?      @relation(fields: [projectId], references: [id])
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ListSection {
  id        String        @id @default(cuid())
  name      String
  order     Int           @default(0)
  createdAt DateTime      @default(now())
  listId    String
  sortBy    String        @default("manual")
  budget    Float?
  unsorted  Boolean       @default(false)
  products  ListProduct[]
  list      ShoppingList  @relation(fields: [listId], references: [id], onDelete: Cascade)
}

model ListProduct {
  id           String               @id @default(cuid())
  name         String
  url          String?
  imageUrl     String?
  price        String?
  manufacturer String?
  color        String?
  dimensions   String?
  description  String?
  deliveryTime String?
  order        Int                  @default(0)
  createdAt    DateTime             @default(now())
  sectionId    String
  quantity     Int                  @default(1)
  category     ListProductCategory?
  hidden        Boolean              @default(false)
  approval      String?
  productId     String?
  supplier      String?
  catalogNumber String?
  section      ListSection          @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  product      Product?             @relation(fields: [productId], references: [id], onDelete: SetNull)
  comments     ListProductComment[]
}

model ListProductComment {
  id        String             @id @default(cuid())
  content   String
  author    String
  createdAt DateTime           @default(now())
  productId String
  product   ListProduct        @relation(fields: [productId], references: [id], onDelete: Cascade)
  replies   ListProductReply[]
}

model ListProductReply {
  id        String             @id @default(cuid())
  content   String
  author    String
  createdAt DateTime           @default(now())
  commentId String
  comment   ListProductComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
}

model Room {
  id        String   @id @default(cuid())
  name      String
  order     Int      @default(0)
  createdAt DateTime @default(now())
  projectId String
  type      RoomType @default(INNE)
  archived  Boolean  @default(false)
  icon      String?
  pinned    Boolean  @default(false)
  folders   Folder[]
  renders   Render[]
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Folder {
  id        String   @id @default(cuid())
  name      String
  roomId    String
  order     Int      @default(0)
  createdAt DateTime @default(now())
  pinned    Boolean  @default(false)
  archived  Boolean  @default(false)
  room      Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  renders   Render[]
}

model Render {
  id                     String                  @id @default(cuid())
  name                   String
  fileUrl                String
  fileKey                String
  order                  Int                     @default(0)
  createdAt              DateTime                @default(now())
  projectId              String
  roomId                 String?
  archived               Boolean                 @default(false)
  status                 RenderStatus            @default(REVIEW)
  viewCount              Int                     @default(0)
  folderId               String?
  pinned                 Boolean                 @default(false)
  comments               Comment[]
  folder                 Folder?                 @relation(fields: [folderId], references: [id])
  project                Project                 @relation(fields: [projectId], references: [id], onDelete: Cascade)
  room                   Room?                   @relation(fields: [roomId], references: [id])
  versions               RenderVersion[]
  versionRestoreRequests VersionRestoreRequest[]
}

model RenderVersion {
  id            String   @id @default(cuid())
  renderId      String
  fileUrl       String
  fileKey       String?
  versionNumber Int
  archivedAt    DateTime @default(now())
  render        Render   @relation(fields: [renderId], references: [id], onDelete: Cascade)
}

model VersionRestoreRequest {
  id         String   @id @default(cuid())
  renderId   String
  versionId  String
  renderName String
  clientName String
  projectId  String
  shareToken String
  status     String   @default("PENDING")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  render     Render   @relation(fields: [renderId], references: [id], onDelete: Cascade)
}

model Comment {
  id         String        @id @default(cuid())
  content    String
  posX       Float?
  posY       Float?
  status     CommentStatus @default(NEW)
  author     String
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  renderId   String
  title      String?
  isInternal Boolean       @default(false)
  render     Render        @relation(fields: [renderId], references: [id], onDelete: Cascade)
  replies    Reply[]
}

model Reply {
  id        String   @id @default(cuid())
  content   String
  author    String
  createdAt DateTime @default(now())
  commentId String
  comment   Comment  @relation(fields: [commentId], references: [id], onDelete: Cascade)
}

model Notification {
  id           String   @id @default(cuid())
  userId       String
  message      String
  link         String
  read         Boolean  @default(false)
  createdAt    DateTime @default(now())
  projectId    String?
  projectTitle String?
  requestId    String?
  type         String   @default("info")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model LoginLog {
  id        String   @id @default(cuid())
  email     String
  userId    String?
  success   Boolean
  createdAt DateTime @default(now())
}

model ActivityLog {
  id        String   @id @default(cuid())
  level     String
  action    String
  message   String
  userId    String?
  meta      String?
  createdAt DateTime @default(now())
}

model StatusChangeRequest {
  id         String   @id @default(cuid())
  renderId   String
  renderName String
  clientName String
  projectId  String
  shareToken String
  status     String   @default("PENDING")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Product {
  id           String               @id @default(cuid())
  name         String
  url          String?
  imageUrl     String?
  price        String?
  manufacturer String?
  color        String?
  dimensions   String?
  description  String?
  deliveryTime  String?
  quantity      Int                  @default(1)
  category      ListProductCategory?
  supplier      String?
  catalogNumber String?
  createdAt     DateTime             @default(now())
  userId        String
  user         User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  listProducts ListProduct[]
}

enum ListProductCategory {
  LAMPY
  AKCESORIA
  MEBLE
  ARMATURA
  OKLADZINY_SCIENNE
  PODLOGA
}

enum RoomType {
  TOALETA
  WC
  SALON
  KUCHNIA
  SYPIALNIA
  INNE
}

enum RenderStatus {
  REVIEW
  ACCEPTED
}

enum CommentStatus {
  NEW
  IN_PROGRESS
  DONE
}
