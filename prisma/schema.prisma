generator client {
  provider        = "prisma-client-js"
  previewFeatures = []
}

datasource db {
  provider = "postgresql"
}

model User {
  id                         String         @id @default(cuid())
  name                       String?
  email                      String         @unique
  emailVerified              DateTime?
  image                      String?
  password                   String?
  createdAt                  DateTime       @default(now())
  updatedAt                  DateTime       @updatedAt
  role                       String         @default("designer") // "designer" | "client" | "contractor"
  fullName                   String?                             // imię i nazwisko
  avatarUrl                  String?                             // custom avatar
  phonePrefix                String?        @default("+48")      // country code prefix
  login                      String?        @unique              // client login e.g. "drychlik"
  phone                      String?                             // contact phone
  allowDirectStatusChange    Boolean        @default(false)
  accentColor                String?
  allowClientAcceptance      Boolean        @default(true)
  allowClientComments        Boolean        @default(true)
  autoArchiveOnAccept        Boolean        @default(false)
  autoClosePinsOnAccept      Boolean        @default(false)
  clientLogoUrl              String?
  clientWelcomeMessage       String?
  defaultRenderOrder         String         @default("order")
  defaultRenderStatus        RenderStatus   @default(REVIEW)
  hideCommentCount           Boolean        @default(false)
  maxPinsPerRender           Int?
  notifyClientOnReply        Boolean        @default(true)
  notifyClientOnStatusChange Boolean        @default(true)
  requireClientEmail         Boolean        @default(false)
  requirePinTitle            Boolean        @default(false)
  allowClientVersionRestore  Boolean        @default(true)
  showProfileName            Boolean        @default(false)
  showClientLogo             Boolean        @default(false)
  isAdmin                    Boolean        @default(false)
  needsNameSetup             Boolean        @default(false)
  globalHiddenModules        String[]       @default([])
  listsCategoryOrder         String[]       @default([])
  navMode                    String         @default("sidebar")
  colorTheme                 String         @default("champagne")
  pdfListTemplate            String         @default("violet")
  extensionKey               String?        @unique
  customCategories           String[]       @default([])
  viewPreferences            Json?
  trialEndsAt                DateTime?                           // null = brak trialu (isFree lub stary user)
  isFree                     Boolean        @default(false)      // admin może oznaczyć usera jako darmowego
  contactEmail               String?                             // real email for notifications (clients use this instead of @client.internal)
  emailNotifEnabled          Boolean        @default(false)      // master toggle — email notifications off by default
  emailNotifModules          String[]       @default([])         // e.g. ["renderflow", "listy"]
  ownerId                    String?
  owner                      User?          @relation("TeamMembers", fields: [ownerId], references: [id])
  teamMembers                User[]         @relation("TeamMembers")
  subscription               Subscription?
  discounts                  Discount[]
  accounts                   Account[]
  calendarEvents             CalendarEvent[]
  calendarGuestEntries       CalendarGuest[]
  notifications              Notification[]
  notes                      Note[]
  products                   Product[]
  projects                   Project[]
  sessions                   Session[]
  shoppingLists              ShoppingList[]
  sentInvitations            Invitation[]   @relation("InvitationDesigner")
  ownedDiscussions           Discussion[]   @relation("DiscussionOwner")
  discussionMessages         DiscussionMessage[] @relation("DiscussionMessageUser")
  projectClientAccounts      ProjectClient[] @relation("ProjectClientUser")
  createdTasks               Task[]         @relation("TaskCreator")
  assignedTasks              Task[]         @relation("TaskAssignee")
  taskComments               TaskComment[]  @relation("TaskCommentAuthor")
  taskStatuses               TaskStatusConfig[]
  models3d                   Model3D[]
  surveys                    Survey[]
  contractors                Contractor[]   @relation("DesignerContractors")
  contractorAccount          Contractor?    @relation("ContractorUser")
  clients                    Client[]       @relation("DesignerClients")
}

model Invitation {
  id         String   @id @default(cuid())
  email      String
  token      String   @unique @default(cuid())
  designerId String
  designer   User     @relation("InvitationDesigner", fields: [designerId], references: [id], onDelete: Cascade)
  status     String   @default("PENDING")
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  type       String   @default("team") // "team" | "client"
  projectId  String?
}

model Subscription {
  id           String    @id @default(cuid())
  userId       String    @unique
  plan         String    // "standard" | "commercial" | "enterprise"
  status       String    @default("active") // "active" | "cancelled"
  billingName  String?
  billingEmail String?
  cardLast4    String?
  cardBrand    String?
  cancelAt     DateTime?                    // ustawione przy anulowaniu — dostęp do tej daty
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Discount {
  id         String    @id @default(cuid())
  userId     String
  type       String    // "percent" | "amount"
  value      Float
  validFrom  DateTime  @default(now())
  validUntil DateTime?
  note       String?
  createdAt  DateTime  @default(now())
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Note {
  id          String           @id @default(cuid())
  title       String?
  content     String
  archived    Boolean          @default(false)
  userId      String
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  attachments NoteAttachment[]
}

model NoteAttachment {
  id        String   @id @default(cuid())
  noteId    String
  name      String
  url       String
  key       String
  createdAt DateTime @default(now())
  note      Note     @relation(fields: [noteId], references: [id], onDelete: Cascade)
}

model CalendarEvent {
  id          String            @id @default(cuid())
  title       String
  type        CalendarEventType
  startAt     DateTime
  endAt       DateTime?
  location    String?
  description String?
  userId      String
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  guests      CalendarGuest[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
}

model CalendarGuest {
  id      String        @id @default(cuid())
  eventId String
  name    String?
  email   String?
  userId  String?
  user    User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  event   CalendarEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

enum CalendarEventType {
  WYDARZENIE
  ZADANIE
  PRZYPOMNIENIE
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Client {
  id                String          @id @default(cuid())
  designerId        String
  designer          User            @relation("DesignerClients", fields: [designerId], references: [id], onDelete: Cascade)
  name              String
  description       String?
  startDate         DateTime?
  endDate           DateTime?
  addressStreet     String?
  addressCity       String?
  addressPostalCode String?
  addressCountry    String?
  hiddenModules     String[]        @default([])
  clientCanUpload   Boolean         @default(false)
  createdAt         DateTime        @default(now())
  archived          Boolean         @default(false)
  projects          Project[]
  contacts          ProjectClient[] @relation("ClientContacts")
}

model Project {
  id             String          @id @default(cuid())
  title          String
  description    String?
  shareToken     String          @unique @default(cuid())
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  userId         String
  clientEmail    String?
  clientName     String?
  clientPhone    String?
  clientId       String?
  archived       Boolean         @default(false)
  shareExpiresAt DateTime?
  sharePassword  String?
  modules        String[]        @default([])
  pinned             Boolean         @default(false)
  hiddenModules      String[]        @default([])
  slug               String?         @unique
  addressCountry     String?
  addressCity        String?
  addressPostalCode  String?
  addressStreet      String?
  clientCanUpload              Boolean         @default(false)
  startDate                    DateTime?
  endDate                      DateTime?
  paymentsSharedWithClient     Boolean         @default(false)
  scheduleSharedWithClient     Boolean         @default(false)
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  client         Client?         @relation(fields: [clientId], references: [id], onDelete: SetNull)
  clients        ProjectClient[]
  renders        Render[]
  rooms          Room[]
  shoppingLists  ShoppingList[]
  discussion     Discussion?
  tasks          Task[]
  surveys        Survey[]
  paymentGroupsAsRfProject PaymentGroup[]  @relation("PaymentGroupRfProject")
  paymentsAsRfProject      Payment[]       @relation("PaymentRfProject")
  schedulePhases           SchedulePhase[] @relation("SchedulePhaseRfProject")
  contractorAssignments    ContractorAssignment[]
}

model ProjectClient {
  id            String         @id @default(cuid())
  name          String
  email         String?
  phone         String?
  projectId     String?        // kept during migration; will be removed after data is migrated
  clientId      String?        // new: references Client entity; will become required after migration
  createdAt     DateTime       @default(now())
  isMainContact Boolean        @default(false)
  order         Int            @default(0)
  startDate     DateTime?
  endDate       DateTime?
  userId        String?
  totalAmount   Float?
  project       Project?       @relation(fields: [projectId], references: [id], onDelete: SetNull)
  client        Client?        @relation("ClientContacts", fields: [clientId], references: [id], onDelete: Cascade)
  user          User?          @relation("ProjectClientUser", fields: [userId], references: [id], onDelete: SetNull)
  paymentGroups PaymentGroup[]
  payments      Payment[]
  docFolders      ClientDocFolder[]
  docs            ClientDoc[]
  surveys         Survey[]
  schedulePhases  SchedulePhase[]
}

model PaymentGroup {
  id           String         @id @default(cuid())
  clientId     String
  parentId     String?
  rfProjectId      String?
  hiddenFromClient Boolean    @default(false)
  name         String
  order        Int            @default(0)
  createdAt    DateTime       @default(now())
  client       ProjectClient  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  parent       PaymentGroup?  @relation("PaymentGroupChildren", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  children     PaymentGroup[] @relation("PaymentGroupChildren")
  payments     Payment[]
  rfProject    Project?       @relation("PaymentGroupRfProject", fields: [rfProjectId], references: [id], onDelete: SetNull)
}

model Payment {
  id             String         @id @default(cuid())
  clientId       String
  groupId        String?
  name           String
  amount         Float
  status         String         @default("pending")
  attachmentUrl  String?
  attachmentName String?
  order          Int            @default(0)
  createdAt      DateTime       @default(now())
  rfProjectId    String?
  client         ProjectClient  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  group          PaymentGroup?  @relation(fields: [groupId], references: [id], onDelete: SetNull)
  rfProject      Project?       @relation("PaymentRfProject", fields: [rfProjectId], references: [id], onDelete: SetNull)
}

model ShoppingList {
  id         String        @id @default(cuid())
  name       String
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  userId     String
  projectId  String?
  shareToken String        @unique @default(cuid())
  archived   Boolean       @default(false)
  pinned     Boolean       @default(false)
  order      Int           @default(0)
  slug       String?       @unique
  budget     Float?
  hidePrices Boolean       @default(false)
  sections   ListSection[]
  project    Project?      @relation(fields: [projectId], references: [id])
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ListSection {
  id        String        @id @default(cuid())
  name      String
  order     Int           @default(0)
  createdAt DateTime      @default(now())
  listId    String
  sortBy    String        @default("manual")
  budget    Float?
  unsorted  Boolean       @default(false)
  products  ListProduct[]
  list      ShoppingList  @relation(fields: [listId], references: [id], onDelete: Cascade)
}

model ListProduct {
  id           String               @id @default(cuid())
  name         String
  url          String?
  imageUrl     String?
  price        String?
  manufacturer String?
  color        String?
  dimensions   String?
  description  String?
  deliveryTime String?
  order        Int                  @default(0)
  createdAt    DateTime             @default(now())
  sectionId    String
  quantity     Int                  @default(1)
  category     String?
  hidden        Boolean              @default(false)
  approval      String?
  productId     String?
  supplier      String?
  catalogNumber String?
  note          String?
  section      ListSection          @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  product      Product?             @relation(fields: [productId], references: [id], onDelete: SetNull)
  comments     ListProductComment[]
}

model ListProductComment {
  id               String             @id @default(cuid())
  content          String
  author           String
  createdAt        DateTime           @default(now())
  productId        String
  viewedByDesigner Boolean            @default(false)
  imageUrl         String?
  product          ListProduct        @relation(fields: [productId], references: [id], onDelete: Cascade)
  replies          ListProductReply[]
}

model ListProductReply {
  id               String             @id @default(cuid())
  content          String
  author           String
  createdAt        DateTime           @default(now())
  viewedByDesigner Boolean            @default(false)
  commentId        String
  comment          ListProductComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
}

model Room {
  id        String   @id @default(cuid())
  name      String
  order     Int      @default(0)
  createdAt DateTime @default(now())
  projectId String
  type      RoomType @default(INNE)
  archived  Boolean  @default(false)
  icon      String?
  pinned    Boolean  @default(false)
  folders   Folder[]
  renders   Render[]
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Folder {
  id        String   @id @default(cuid())
  name      String
  roomId    String
  order     Int      @default(0)
  createdAt DateTime @default(now())
  pinned    Boolean  @default(false)
  archived  Boolean  @default(false)
  room      Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  renders   Render[]
}

model Render {
  id                     String                  @id @default(cuid())
  name                   String
  fileUrl                String
  fileKey                String
  order                  Int                     @default(0)
  createdAt              DateTime                @default(now())
  projectId              String
  roomId                 String?
  archived               Boolean                 @default(false)
  status                 RenderStatus            @default(REVIEW)
  viewCount              Int                     @default(0)
  folderId               String?
  pinned                 Boolean                 @default(false)
  fileType               String                  @default("image")
  comments               Comment[]
  productPins            RenderProductPin[]
  folder                 Folder?                 @relation(fields: [folderId], references: [id])
  project                Project                 @relation(fields: [projectId], references: [id], onDelete: Cascade)
  room                   Room?                   @relation(fields: [roomId], references: [id])
  versions               RenderVersion[]
  versionRestoreRequests VersionRestoreRequest[]
  contractorFiles        ContractorFile[]
}

model RenderProductPin {
  id        String   @id @default(cuid())
  renderId  String
  productId String
  posX      Float
  posY      Float
  createdAt DateTime @default(now())
  archivedVersionId String?

  render          Render         @relation(fields: [renderId], references: [id], onDelete: Cascade)
  product         Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  archivedVersion RenderVersion? @relation("ProductPinArchivedVersion", fields: [archivedVersionId], references: [id])
}

model RenderVersion {
  id            String   @id @default(cuid())
  renderId      String
  fileUrl       String
  fileKey       String?
  versionNumber Int
  archivedAt    DateTime @default(now())
  render        Render   @relation(fields: [renderId], references: [id], onDelete: Cascade)
  archivedComments    Comment[]          @relation("CommentArchivedVersion")
  archivedProductPins RenderProductPin[] @relation("ProductPinArchivedVersion")
}

model VersionRestoreRequest {
  id         String   @id @default(cuid())
  renderId   String
  versionId  String
  renderName String
  clientName String
  projectId  String
  shareToken String
  status     String   @default("PENDING")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  render     Render   @relation(fields: [renderId], references: [id], onDelete: Cascade)
}

model Comment {
  id         String        @id @default(cuid())
  content    String
  posX       Float?
  posY       Float?
  posPage    Int?
  status     CommentStatus @default(NEW)
  author     String
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  renderId   String
  title      String?
  isInternal        Boolean       @default(false)
  fromDesigner      Boolean       @default(false)
  isAiSummary       Boolean       @default(false)
  viewedByDesigner  Boolean       @default(false)
  voiceUrl          String?
  imageUrl          String?
  archivedVersionId String?
  replyToId         String?
  replyToContent    String?
  replyToAuthor     String?
  render          Render         @relation(fields: [renderId], references: [id], onDelete: Cascade)
  archivedVersion RenderVersion? @relation("CommentArchivedVersion", fields: [archivedVersionId], references: [id])
  replies    Reply[]
}

model Reply {
  id               String   @id @default(cuid())
  content          String
  author           String
  voiceUrl         String?
  replyToId        String?
  replyToContent   String?
  replyToAuthor    String?
  createdAt        DateTime @default(now())
  viewedByDesigner Boolean  @default(false)
  commentId        String
  comment          Comment  @relation(fields: [commentId], references: [id], onDelete: Cascade)
}

model Notification {
  id           String   @id @default(cuid())
  userId       String
  message      String
  link         String
  read         Boolean  @default(false)
  createdAt    DateTime @default(now())
  projectId    String?
  projectTitle String?
  requestId    String?
  type         String   @default("info")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model LoginLog {
  id        String   @id @default(cuid())
  email     String
  userId    String?
  success   Boolean
  createdAt DateTime @default(now())
}

model ActivityLog {
  id        String   @id @default(cuid())
  level     String
  action    String
  message   String
  userId    String?
  meta      String?
  createdAt DateTime @default(now())
}

model StatusChangeRequest {
  id         String   @id @default(cuid())
  renderId   String
  renderName String
  clientName String
  projectId  String
  shareToken String
  status     String   @default("PENDING")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Product {
  id           String               @id @default(cuid())
  name         String
  url          String?
  imageUrl     String?
  price        String?
  manufacturer String?
  color        String?
  dimensions   String?
  description  String?
  deliveryTime  String?
  quantity      Int                  @default(1)
  category      String?
  supplier      String?
  catalogNumber String?
  favorite      Boolean              @default(false)
  createdAt     DateTime             @default(now())
  userId        String
  user         User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  listProducts ListProduct[]
  renderPins   RenderProductPin[]
}

model Discussion {
  id                     String   @id @default(cuid())
  title                  String
  type                   String   @default("internal") // "project" | "internal" | "contractor"
  ownerId                String
  projectId              String?  @unique
  contractorAssignmentId String?  @unique
  archived               Boolean  @default(false)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  owner                User                    @relation("DiscussionOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  project              Project?                @relation(fields: [projectId], references: [id], onDelete: Cascade)
  contractorAssignment ContractorAssignment?   @relation(fields: [contractorAssignmentId], references: [id], onDelete: SetNull)
  messages             DiscussionMessage[]
  readReceipts         DiscussionReadReceipt[]
}

model DiscussionMessage {
  id           String   @id @default(cuid())
  discussionId String
  content      String
  authorName   String
  userId       String?
  clientEmail  String?
  sourceType   String   @default("chat") // "chat" | "render_comment" | "render_pin" | "product_comment"
  sourceId        String?
  sourceUrl       String?
  sourceName      String?
  sourceImageUrl  String?
  attachmentUrl  String?
  attachmentName String?
  attachmentType String? // "image" | "document"
  replyToId      String?
  replyToContent String?
  replyToAuthor  String?
  createdAt      DateTime @default(now())
  editedAt       DateTime?

  discussion   Discussion              @relation(fields: [discussionId], references: [id], onDelete: Cascade)
  user         User?                   @relation("DiscussionMessageUser", fields: [userId], references: [id], onDelete: SetNull)
  readReceipts DiscussionReadReceipt[]
}

model DiscussionReadReceipt {
  id            String   @id @default(cuid())
  discussionId  String
  readerId      String   // userId for designers, "client:<authorName>" for clients
  readerName    String
  readerType    String   // "designer" | "client"
  lastMessageId String?
  readAt        DateTime @default(now())

  discussion   Discussion        @relation(fields: [discussionId], references: [id], onDelete: Cascade)
  lastMessage  DiscussionMessage? @relation(fields: [lastMessageId], references: [id], onDelete: SetNull)

  @@unique([discussionId, readerId])
}


enum RoomType {
  TOALETA
  WC
  SALON
  KUCHNIA
  SYPIALNIA
  INNE
}

enum RenderStatus {
  REVIEW
  ACCEPTED
}

enum CommentStatus {
  NEW
  IN_PROGRESS
  DONE
}

model ClientDocFolder {
  id        String         @id @default(cuid())
  clientId  String
  name      String
  order     Int            @default(0)
  pinned    Boolean        @default(false)
  archived  Boolean        @default(false)
  createdAt DateTime       @default(now())
  client    ProjectClient  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  docs      ClientDoc[]
}

model ClientDoc {
  id        String           @id @default(cuid())
  clientId  String
  folderId  String?
  name      String
  fileUrl   String
  fileKey   String
  fileType  String           @default("file")
  order     Int              @default(0)
  pinned    Boolean          @default(false)
  archived  Boolean          @default(false)
  createdAt DateTime         @default(now())
  client    ProjectClient    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  folder    ClientDocFolder? @relation(fields: [folderId], references: [id], onDelete: SetNull)
}

model Task {
  id          String       @id @default(cuid())
  title       String
  description String?
  status      String       @default("TODO")
  priority    TaskPriority @default(MEDIUM)
  dueDate     DateTime?
  projectId   String?
  project     Project?     @relation(fields: [projectId], references: [id], onDelete: SetNull)
  creatorId   String
  creator     User         @relation("TaskCreator", fields: [creatorId], references: [id], onDelete: Cascade)
  assigneeId  String?
  assignee    User?        @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  ownerId     String
  parentId    String?
  parent      Task?        @relation("SubTasks", fields: [parentId], references: [id], onDelete: Cascade)
  subTasks    Task[]       @relation("SubTasks")
  comments    TaskComment[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model TaskStatusConfig {
  id        String   @id @default(cuid())
  value     String
  label     String
  color     String   @default("#6b7280")
  order     Int      @default(0)
  ownerId   String
  owner     User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([ownerId, value])
}

model TaskComment {
  id        String   @id @default(cuid())
  body      String
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation("TaskCommentAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}


enum TaskPriority {
  LOW
  MEDIUM
  HIGH
}

model Survey {
  id             String          @id @default(cuid())
  name           String
  slug           String          @unique
  shareToken     String          @unique @default(cuid())
  status         String          @default("DRAFT") // DRAFT | ACTIVE | CLOSED
  archived       Boolean         @default(false)
  pinned         Boolean         @default(false)
  order          Int             @default(0)
  userId         String
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId      String?
  project        Project?        @relation(fields: [projectId], references: [id], onDelete: SetNull)
  clientId       String?
  client         ProjectClient?  @relation(fields: [clientId], references: [id], onDelete: SetNull)
  lastReminderAt DateTime?
  isTemplate     Boolean         @default(false)
  sections       SurveySection[]
  questions      SurveyQuestion[]
  responses      SurveyResponse[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model SurveySection {
  id        String           @id @default(cuid())
  name      String
  order     Int              @default(0)
  surveyId  String
  survey    Survey           @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  questions SurveyQuestion[]
}

model SurveyQuestion {
  id          String          @id @default(cuid())
  label       String
  description String?
  type        String
  required    Boolean         @default(false)
  order       Int             @default(0)
  options     Json?
  config      Json?
  sectionId   String?
  section     SurveySection?  @relation(fields: [sectionId], references: [id], onDelete: SetNull)
  surveyId    String
  survey      Survey          @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  answers     SurveyAnswer[]
}

model SurveyResponse {
  id              String        @id @default(cuid())
  respondentEmail String
  respondentName  String?
  completedAt     DateTime?
  viewCount       Int           @default(0)
  surveyId        String
  survey          Survey        @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  answers         SurveyAnswer[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model SurveyAnswer {
  id         String         @id @default(cuid())
  value      Json
  questionId String
  question   SurveyQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  responseId String
  response   SurveyResponse @relation(fields: [responseId], references: [id], onDelete: Cascade)
  createdAt  DateTime       @default(now())
}

model Model3D {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name         String
  category     String
  meshyTaskId  String?
  thumbnailUrl String?
  urlGlb       String?
  urlObj       String?
  urlStl       String?
  urlFbx       String?
  createdAt    DateTime @default(now())
}

model SchedulePhase {
  id          String        @id @default(cuid())
  clientId    String
  rfProjectId String?
  name        String
  startDate   DateTime?
  endDate     DateTime?
  done        Boolean       @default(false)
  hidden      Boolean       @default(false)
  order       Int           @default(0)
  createdAt   DateTime      @default(now())
  client      ProjectClient @relation(fields: [clientId], references: [id], onDelete: Cascade)
  rfProject   Project?      @relation("SchedulePhaseRfProject", fields: [rfProjectId], references: [id], onDelete: SetNull)
  items       ScheduleItem[]
}

model ScheduleItem {
  id          String        @id @default(cuid())
  phaseId     String
  name        String
  description String?
  startDate   DateTime?
  endDate     DateTime?
  done        Boolean       @default(false)
  hidden      Boolean       @default(false)
  isSection   Boolean       @default(false)
  order       Int           @default(0)
  createdAt   DateTime      @default(now())
  phase       SchedulePhase @relation(fields: [phaseId], references: [id], onDelete: Cascade)
}

model Contractor {
  id          String   @id @default(cuid())
  designerId  String
  designer    User     @relation("DesignerContractors", fields: [designerId], references: [id], onDelete: Cascade)
  userId      String?  @unique
  user        User?    @relation("ContractorUser", fields: [userId], references: [id], onDelete: SetNull)
  name        String
  company     String?
  trade       String?
  email       String?
  phone       String?
  createdAt   DateTime @default(now())
  assignments ContractorAssignment[]
}

model ContractorAssignment {
  id           String     @id @default(cuid())
  contractorId String
  contractor   Contractor @relation(fields: [contractorId], references: [id], onDelete: Cascade)
  projectId    String
  project      Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  designerId   String
  archived     Boolean    @default(false)
  createdAt    DateTime   @default(now())
  // Project info visible to contractor
  investmentStreet      String?
  investmentCity        String?
  investmentPostalCode  String?
  investmentCountry     String?
  designerContactName   String?
  designerContactPhone  String?
  investorContactName   String?
  investorContactPhone  String?
  projectNotes          String?
  folders      ContractorFolder[]
  discussion   Discussion?

  @@unique([contractorId, projectId])
}

model ContractorFolder {
  id           String               @id @default(cuid())
  assignmentId String
  assignment   ContractorAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  parentId     String?
  parent       ContractorFolder?    @relation("SubFolders", fields: [parentId], references: [id], onDelete: Cascade)
  subfolders   ContractorFolder[]   @relation("SubFolders")
  name         String
  type         String
  visible      Boolean              @default(true)
  order        Int                  @default(0)
  createdAt    DateTime             @default(now())
  files        ContractorFile[]
}

model ContractorFile {
  id           String                  @id @default(cuid())
  folderId     String
  folder       ContractorFolder        @relation(fields: [folderId], references: [id], onDelete: Cascade)
  name         String
  renderId     String?
  render       Render?                 @relation(fields: [renderId], references: [id], onDelete: SetNull)
  fileUrl      String?
  fileKey      String?
  fileType     String                  @default("image")
  uploadedById String
  createdAt    DateTime                @default(now())
  comments     ContractorFileComment[]
}

model ContractorFileComment {
  id                 String                 @id @default(cuid())
  content            String
  author             String
  authorRole         String                 @default("contractor") // "contractor" | "designer"
  createdAt          DateTime               @default(now())
  fileId             String
  viewedByDesigner   Boolean                @default(false)
  viewedByContractor Boolean                @default(false)
  file               ContractorFile         @relation(fields: [fileId], references: [id], onDelete: Cascade)
  replies            ContractorFileReply[]
}

model ContractorFileReply {
  id                 String                @id @default(cuid())
  content            String
  author             String
  authorRole         String                @default("designer") // "contractor" | "designer"
  createdAt          DateTime              @default(now())
  commentId          String
  viewedByContractor Boolean               @default(false)
  comment            ContractorFileComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
}
